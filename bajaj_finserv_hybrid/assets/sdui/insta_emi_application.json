{
  "type": "scaffold",
  "backgroundColor": "#F5F7FA",
  "appBar": {
    "type": "appBar",
    "backgroundColor": "#002A54",
    "foregroundColor": "#FFFFFF",
    "title": { "type": "text", "data": "Complete Application", "style": { "color": "#FFFFFF", "fontSize": 18, "fontWeight": "bold" } }
  },
  "body": {
    "type": "form",
    "child": {
      "type": "singleChildScrollView",
      "padding": { "top": 22, "left": 16, "right": 16, "bottom": 48 },
      "child": {
        "type": "column",
        "crossAxisAlignment": "start",
        "children": [
        { "type": "text", "data": "Step 2 of 3", "style": { "fontSize": 12, "fontWeight": "bold", "color": "#FF6B35" } },
        { "type": "sizedBox", "height": 8 },
        { "type": "linearProgressIndicator", "value": 0.66, "minHeight": 7, "backgroundColor": "#DCE4EC", "color": "#FF6B35" },
        { "type": "sizedBox", "height": 24 },
        { "type": "text", "data": "Tell us about yourself", "style": { "fontSize": 22, "fontWeight": "bold", "color": "#162B49" } },
        { "type": "sizedBox", "height": 8 },
        { "type": "text", "data": "We use these details to verify your eligibility and personalise your card limit.", "style": { "fontSize": 13, "color": "#64748B" } },
        {
          "type": "container",
          "margin": { "top": 24, "bottom": 22 },
          "padding": { "all": 20 },
          "decoration": { "color": "#FFFFFF", "borderRadius": 8, "border": { "color": "#E2E8F0", "width": 1 } },
          "child": {
            "type": "column",
            "crossAxisAlignment": "start",
            "children": [
              { "type": "text", "data": "Personal details", "style": { "fontSize": 18, "fontWeight": "bold", "color": "#162B49" } },
              { "type": "sizedBox", "height": 18 },
              { "type": "text", "data": "Full name as per PAN", "style": { "fontSize": 12, "fontWeight": "w500" } },
              { "type": "sizedBox", "height": 8 },
              { "type": "textFormField", "id": "fullName", "keyboardType": "name", "textInputAction": "next", "decoration": { "hintText": "Enter full name", "border": { "type": "outlineInputBorder", "borderRadius": 6 } } },
              { "type": "sizedBox", "height": 18 },
              { "type": "text", "data": "Mobile number", "style": { "fontSize": 12, "fontWeight": "w500" } },
              { "type": "sizedBox", "height": 8 },
              { "type": "textFormField", "id": "mobile", "keyboardType": "phone", "maxLength": 10, "textInputAction": "next", "decoration": { "hintText": "10-digit mobile number", "border": { "type": "outlineInputBorder", "borderRadius": 6 } } },
              { "type": "sizedBox", "height": 18 },
              { "type": "text", "data": "PAN number", "style": { "fontSize": 12, "fontWeight": "w500" } },
              { "type": "sizedBox", "height": 8 },
              { "type": "textFormField", "id": "pan", "keyboardType": "text", "maxLength": 10, "textCapitalization": "characters", "textInputAction": "next", "decoration": { "hintText": "ABCDE1234F", "border": { "type": "outlineInputBorder", "borderRadius": 6 } } },
              { "type": "sizedBox", "height": 18 },
              { "type": "text", "data": "Date of birth", "style": { "fontSize": 12, "fontWeight": "w500" } },
              { "type": "sizedBox", "height": 8 },
              { "type": "textFormField", "id": "dob", "keyboardType": "datetime", "textInputAction": "next", "decoration": { "hintText": "DD/MM/YYYY", "border": { "type": "outlineInputBorder", "borderRadius": 6 } } }
            ]
          }
        },
        {
          "type": "container",
          "margin": { "bottom": 22 },
          "padding": { "all": 20 },
          "decoration": { "color": "#FFFFFF", "borderRadius": 8, "border": { "color": "#E2E8F0", "width": 1 } },
          "child": {
            "type": "column",
            "crossAxisAlignment": "start",
            "children": [
              { "type": "text", "data": "Employment and income", "style": { "fontSize": 18, "fontWeight": "bold", "color": "#162B49" } },
              { "type": "sizedBox", "height": 18 },
              { "type": "text", "data": "Employment type", "style": { "fontSize": 12, "fontWeight": "w500" } },
              { "type": "sizedBox", "height": 8 },
              { "type": "textFormField", "id": "employment", "keyboardType": "text", "textInputAction": "next", "decoration": { "hintText": "Salaried / Self-employed", "border": { "type": "outlineInputBorder", "borderRadius": 6 } } },
              { "type": "sizedBox", "height": 18 },
              { "type": "text", "data": "Monthly income", "style": { "fontSize": 12, "fontWeight": "w500" } },
              { "type": "sizedBox", "height": 8 },
              { "type": "textFormField", "id": "income", "keyboardType": "number", "textInputAction": "next", "decoration": { "prefixText": "Rs. ", "hintText": "Enter monthly income", "border": { "type": "outlineInputBorder", "borderRadius": 6 } } },
              { "type": "sizedBox", "height": 18 },
              { "type": "text", "data": "Current city", "style": { "fontSize": 12, "fontWeight": "w500" } },
              { "type": "sizedBox", "height": 8 },
              { "type": "textFormField", "id": "city", "keyboardType": "text", "textCapitalization": "words", "textInputAction": "done", "decoration": { "hintText": "Enter current city", "border": { "type": "outlineInputBorder", "borderRadius": 6 } } }
            ]
          }
        },
        {
          "type": "container",
          "margin": { "bottom": 22 },
          "padding": { "all": 20 },
          "decoration": { "color": "#EAF3FA", "borderRadius": 8 },
          "child": {
            "type": "column",
            "crossAxisAlignment": "start",
            "children": [
              { "type": "text", "data": "Your selected offer", "style": { "fontSize": 17, "fontWeight": "bold", "color": "#002A54" } },
              { "type": "sizedBox", "height": 16 },
              { "type": "row", "mainAxisAlignment": "spaceBetween", "children": [{ "type": "text", "data": "Insta EMI Card limit", "style": { "fontSize": 13 } }, { "type": "text", "data": "Up to Rs. 3,00,000", "style": { "fontSize": 14, "fontWeight": "bold" } }] },
              { "type": "divider", "height": 28 },
              { "type": "row", "mainAxisAlignment": "spaceBetween", "children": [{ "type": "text", "data": "Amount payable now", "style": { "fontSize": 13 } }, { "type": "text", "data": "Rs. 530", "style": { "fontSize": 14, "fontWeight": "bold" } }] }
            ]
          }
        },
        {
          "type": "container",
          "margin": { "bottom": 24 },
          "padding": { "all": 18 },
          "decoration": { "color": "#FFF7F2", "borderRadius": 8, "border": { "color": "#FFD7C7", "width": 1 } },
          "child": {
            "type": "row",
            "crossAxisAlignment": "start",
            "children": [
              { "type": "icon", "icon": "verified_user", "color": "#FF6B35", "size": 24 },
              { "type": "sizedBox", "width": 12 },
              { "type": "expanded", "child": { "type": "text", "data": "By continuing, you consent to identity verification, credit bureau checks, and the applicable terms and conditions.", "style": { "fontSize": 12, "color": "#475569" } } }
            ]
          }
        },
        {
          "type": "sizedBox",
          "width": "infinity",
          "height": 52,
          "child": {
            "type": "elevatedButton",
            "style": { "backgroundColor": "#FF6B35", "shape": { "type": "roundedRectangle", "borderRadius": 6 } },
            "onPressed": {
              "actionType": "printFormData",
              "ids": ["fullName", "mobile", "pan", "dob", "employment", "income", "city"]
            },
            "child": { "type": "text", "data": "VERIFY AND CONTINUE", "style": { "fontSize": 15, "fontWeight": "bold", "color": "#FFFFFF" } }
          }
        },
        { "type": "sizedBox", "height": 14 },
        { "type": "text", "data": "Your information is encrypted and handled securely.", "textAlign": "center", "style": { "fontSize": 11, "color": "#64748B" } }
        ]
      }
    }
  }
}
